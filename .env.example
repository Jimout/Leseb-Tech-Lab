# Public site URL (canonical links, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (Prisma) — required for admin login and content
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/leseb

# NextAuth — required for /leseb-admin login
# Generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Cloudinary — required for production uploads; optional in local dev
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

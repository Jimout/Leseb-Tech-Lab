generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  purchases     Purchase[]
  updatedSidebarMenus AdminSidebarMenu[] @relation("AdminSidebarMenuUpdatedBy")
  createdWorks  Work[]    @relation("WorkCreatedBy")
  updatedWorks  Work[]    @relation("WorkUpdatedBy")
  createdInsights Insight[] @relation("InsightCreatedBy")
  updatedInsights Insight[] @relation("InsightUpdatedBy")
}

model Work {
  id              String   @id @default(cuid())
  publicId        String   @unique
  slug            String   @unique
  heroMedia       Json?
  mediaAssets     Json?
  year            String
  location        String
  title           String
  category        String
  cardSummary     String   @default("")
  filterIds       String[]
  detail          Json?
  sortOrder       Int      @default(0)
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUser   User?    @relation("WorkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?    @relation("WorkUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([sortOrder])
  @@index([slug])
}

model Insight {
  id              String   @id @default(cuid())
  publicId        String   @unique
  slug            String   @unique
  date            String
  dateIso         String
  title           String
  description     String
  heroMedia       Json?
  mediaAssets     Json?
  href            String
  filterIds       String[]
  bodyMode        String?
  simpleBodyHtml  String?
  article         Json?
  sortOrder       Int      @default(0)
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUser   User?    @relation("InsightCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?    @relation("InsightUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([sortOrder])
  @@index([slug])
}

/// Old public slugs → entity (for 301 redirect after rename). `oldSlug` is globally unique.
model SlugHistory {
  id         String   @id @default(cuid())
  entityId   String
  entityType String
  oldSlug    String   @unique
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model Product {
  id           String     @id @default(cuid())
  name         String
  price        Int
  filePublicId String
  createdAt    DateTime   @default(now())
  purchases    Purchase[]
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Singleton JSON document (hero, footer, pages, etc.) — id is always "default".
model GlobalSiteSettings {
  id        String   @id @default("default")
  data      Json
  updatedAt DateTime @updatedAt
}

model AdminSidebarMenu {
  id              String               @id @default("default")
  updatedByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  items           AdminSidebarMenuItem[]
  updatedByUser   User?                @relation("AdminSidebarMenuUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

model AdminSidebarMenuItem {
  id         String           @id @default(cuid())
  menuId     String
  groupId    String
  groupLabel String
  groupOrder Int              @default(0)
  itemOrder  Int              @default(0)
  href       String
  label      String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  menu       AdminSidebarMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([menuId, groupOrder, itemOrder])
  @@unique([menuId, href])
}

model Subscriber {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  status               SubscriberStatus       @default(PENDING)
  confirmTokenHash     String?
  unsubscribeTokenHash String?
  notifyWork           Boolean                @default(true)
  notifyInsights       Boolean                @default(true)
  notifyImportant      Boolean                @default(true)
  createdAt            DateTime               @default(now())
  confirmedAt          DateTime?
  unsubscribedAt       DateTime?
  lastNotifiedAt       DateTime?
  deliveries           NotificationDelivery[]
}

model NotificationEvent {
  id           String                 @id @default(cuid())
  type         NotificationType
  title        String
  summary      String?
  url          String
  entityId     String?
  createdAt    DateTime               @default(now())
  dispatchedAt DateTime?
  deliveries   NotificationDelivery[]
}

model NotificationDelivery {
  id            String         @id @default(cuid())
  eventId       String
  subscriberId  String
  status        DeliveryStatus @default(PENDING)
  retryCount    Int            @default(0)
  nextAttemptAt DateTime       @default(now())
  /// Last delivery attempt (success or failure).
  lastAttemptAt DateTime?
  /// Last failure reason when status is FAILED (truncated in application code).
  error         String?
  sentAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  event        NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subscriber   Subscriber        @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([eventId, subscriberId])
}

/// Singleton row (id = default): dispatch lock lease + last completed run metadata for admin visibility.
model NotificationSystemState {
  id                  String    @id @default("default")
  /// While set and in the future, another dispatch must not start (cross-instance).
  dispatchLockedUntil DateTime?
  lastDispatchAt      DateTime?
  lastDispatchSummary Json?
  updatedAt           DateTime  @updatedAt
}

model PageVisit {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  userAgent   String?
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

enum NotificationType {
  WORK_PUBLISHED
  INSIGHT_PUBLISHED
  IMPORTANT_UPDATE
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

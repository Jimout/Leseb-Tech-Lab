# Public site URL (canonical links, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/leseb

# NextAuth — required for /admin login (generate secret: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Admin credentials provider (optional — defaults match scripts/ensure-admin.cjs)
ADMIN_EMAIL=admin@leseb.com
ADMIN_PASSWORD=admin123

# Cloudinary — required for production uploads; optional in local dev (falls back to public/uploads/dev/)
# Dashboard: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

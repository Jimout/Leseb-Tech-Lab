# Public site URL (canonical links, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/leseb

# NextAuth — required for /admin login (generate secret: openssl rand -base64 32)
# On Vercel (Production): set all of these, then redeploy.
# NEXTAUTH_URL = https://leseb-tech-lab-et.vercel.app  (no trailing slash)
# NEXTAUTH_SECRET = output of: openssl rand -base64 32
# NEXT_PUBLIC_SITE_URL = same as NEXTAUTH_URL
# DATABASE_URL = your Neon Postgres URL
# ADMIN_EMAIL / ADMIN_PASSWORD = admin login for credentials provider
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Admin credentials provider (optional — defaults match scripts/ensure-admin.cjs)
ADMIN_EMAIL=admin@leseb.com
ADMIN_PASSWORD=admin123

# Cloudinary — required for production uploads; optional in local dev (falls back to public/uploads/dev/)
# Dashboard: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
